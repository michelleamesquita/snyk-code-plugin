{
  "name": "snyk-code",
  "version": "1.0.0",
  "description": "Plugin de segurança SAST para Claude Code usando Snyk. Inclui skill de workflow, hooks automáticos (scan pós-edição, bloqueio de commit, relatório final) e referências CWE/OWASP LLM Top 10.",
  "author": "Michelle",
  "license": "MIT",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/snyk-post-edit.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/snyk-pre-commit.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/snyk-stop-report.py"
          }
        ]
      }
    ]
  }
}
